<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">


  <style>
    body {
      background: #f1f4f9;
    font-family: 'Nunito', sans-serif;
    }

    .profile-container {
      max-width: 700px;
      margin: 50px auto;
      padding: 25px;
      border-radius: 20px;
      background: #fff;
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    .profile-header {
      text-align: center;
      margin-bottom: 30px;
    }

    .profile-header img {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 2px solid black;
      object-fit: cover;
      margin-bottom: 15px;
    }

    .profile-header h2 {
      font-weight: 700;
      color: #0d6efd;
    }

    .profile-header p {
      color: #6c757d;
    }

    .profile-info .info-item {
      display: flex;
      align-items: center;
      margin-bottom: 15px;
    }

    .info-item i {
      font-size: 1.2rem;
      color: #0d6efd;
      margin-right: 10px;
    }

    .badge-skill {
      background-color: #16aedc;
      color: white;
      margin: 4px;
      padding: 6px 14px;
      font-size: 0.9rem;
      border-radius: 20px;
      display: inline-block;
    }

    .edit-btn {
      display: block;
      margin: 30px auto 0;
      padding: 10px 25px;
      border-radius: 25px;
      background: #0d6efd;
      color: #fff;
      font-weight: 600;
      text-decoration: none;
      transition: 0.3s ease;
    }

    .edit-btn:hover {
      background: #084298;
      text-decoration: none;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="profile-container">
      <% if(data) { %>
        <div class="profile-header">
    <img src="<%= data.profileImg %>" alt="Male Avatar">
 
          
          <h2><%= data.name %></h2>
          <p><i class="bi bi-envelope"></i> <%= data.email %></p>
        </div>

        <div class="profile-info">
          <div class="info-item">
            <i class="bi bi-telephone-fill"></i>
            <span><strong>Contact:</strong> <%= data.contact %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-gender-neuter"></i>
            <span><strong>Gender:</strong> <%= data.gender %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-building"></i>
            <span><strong>University:</strong> <%= data.university %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-building"></i>
            <span><strong>Course:</strong> <%= data.course %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-building"></i>
            <span><strong>Semester:</strong> <%= data.semester %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-calendar3"></i>
            <span><strong>Batch:</strong> <%= data.batch %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-lightbulb-fill"></i>
            <span><strong>Skills:</strong></span>
          </div>
          <div>
            <% data.skills.forEach(skill => { %>
              <span class="badge-skill"><%= skill %></span>
            <% }) %>
          </div>
        </div>

        <a href="/user/edit/<%= data._id %>" class="edit-btn">
          <i class="bi bi-pencil-square"></i> Edit Profile
        </a>
        <a href="/" class="edit-btn">
          <i class="bi bi-pencil-square"></i> Back to Home
        </a>

      <% } else { %>
        <div class="alert alert-warning text-center">
          No data found.
        </div>
         <a href="/" class="edit-btn">
          <i class="bi bi-pencil-square"></i> Back to Home
        </a>
      <% } %>
    </div>
  </div>

  <!-- Bootstrap + Icons -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</body>
</html>
