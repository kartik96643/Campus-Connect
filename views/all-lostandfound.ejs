<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lost And Found List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f4f6f9;
            margin: 0;
        }

        h2 {
            text-align: center;
            margin-bottom: 30px;
            margin-top: 60px;
            color: #333;
            font-weight: bold;
        }

        .items-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            max-width: 950px;
            margin: auto;
            margin-top: 20px;
            padding-bottom: 40px;
        }

        .item-card {
            display: flex;
            gap: 20px;
            align-items: flex-start;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
            padding: 20px;
            transition: transform 0.2s ease-in-out, box-shadow 0.2s;
        }

        .item-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .item-image {
            width: 220px;
            height: 160px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid #e0e0e0;
        }

        .item-details {
            flex: 1;
        }

        .item-details p {
            margin: 6px 0;
            color: #555;
            line-height: 1.6;
        }

        .item-details strong {
            color: #333;
        }

        .founder {
            margin-top: 12px;
            font-size: 14px;
        }

        .founder a {
            text-decoration: none;
            color: #007bff;
            font-weight: bold;
        }

        .founder a:hover {
            text-decoration: underline;
        }

        .no-data {
            text-align: center;
            margin-top: 80px;
            color: #777;
            font-size: 18px;
        }
    </style>
</head>
<body>
    <%- include('navbar.ejs') %>
    <% if(locals.user){ %>
        <h2>Lost & Found Items</h2>

        <% if(all && all.length > 0){ %>
            <div class="items-container">
                <% all.map((a)=>{ %>
                    <div class="item-card">
                        <img src="<%= a.ItemImageUrl %>" alt="Lost Item Image" class="item-image">

                        <div class="item-details">
                            <p><strong>Description:</strong> <%= a.message %></p>
                            <p class="founder">Posted by: 
                                <a href="/user/<%= a.founderId %>"><%= a.founderId %></a>
                            </p>
                            <p class="founder">Posted on: <%= a.timestamp.toLocaleString('en-US',{dateStyle:'full'}) %></p>
                        </div>
                         <% if(locals.user._id !== a.founderId.toString()) {%>
                      <a href="/chat/<%= a.founderId %>" class="btn btn-sm btn-outline-success">Chat</a>
                      <% } %>
                        <% if(locals.user.role === "ADMIN" || locals.user._id === a.founderId.toString()) {%>
                        <a href="/lostandfound/delete/<%= a._id %>" class="btn btn-warning">Delete</a>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="no-data">No Lost and Found Data</div>
        <% } %>
    <% }else{ %>
        <h4 class="mt-4 text-center">You have to create account or login your account to access this.</h4>
          <% } %>
</body>
</html>
