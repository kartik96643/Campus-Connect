<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CampusConnect</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">


  <style>
    body {
      background-color: #f8f9fa;
          font-family: 'Nunito', sans-serif;

    }

    /* Navbar */
    .navbar {
      background: #fff;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
      padding: 0.8rem 1.5rem;
      margin-bottom: 30px;
    }

    /* Brand */
    .navbar-brand {
      font-weight: 700;
      font-size: 1.5rem;
      color: #111 !important;
      letter-spacing: 0.5px;
    }

    .navbar-brand i {
      font-size: 1.6rem;
      color: #007bff;
      margin-right: 8px;
    }

    .navbar-brand .highlight {
      color: #007bff;
      font-weight: 800;
    }

    /* Nav links */
    .navbar-nav .nav-link {
      color: #333 !important;
      font-size: 1rem;
      margin-left: 1rem;
      font-weight: 500;
      transition: color 0.3s ease;
    }

    /* Hover effect */
    .navbar-nav .nav-link:hover {
      color: #007bff !important;
    }

    /* Logout button */
    .logout-btn {
      background: #fff;
      color: #fff !important;
      border-radius: 6px;
      padding: 6px 12px;
      font-weight: 500;
      margin-left: 1rem;
    }


    /* Responsive fix */
    @media (max-width: 768px) {
      .navbar-nav .nav-link {
        margin-left: 0;
        margin-top: 0.6rem;
      }
      .logout-btn {
        margin-left: 0;
        margin-top: 0.6rem;
      }
    }
  </style>
</head>

<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container-fluid">
      <!-- Brand -->
      <a class="navbar-brand d-flex align-items-center" href="/">
        <i class="bi bi-mortarboard-fill"></i>
        Campus<span class="highlight">Connect</span>
      </a>

      <!-- Toggler -->
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
        aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Menu -->
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <% if (locals.user) { %>
            <li class="nav-item">
              <a class="nav-link active" href="/user/profile/<%=user._id%>">
                <i class="bi bi-person-circle"></i> <%= user.name %>
              </a>
            </li>
            <% if(locals.user.role === "ADMIN"){ %>
               <li class="nav-item">
              <a class="nav-link active" href="/admin/allUsers">
                <i class="bi bi-person-circle"></i> Users
              </a>
            </li>
              <% } %>

            <li class="nav-item">
              <a class="nav-link " href="/complaint">
                 <i class="bi bi-card-list"></i>Complaint/Issue
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/lostandfound">
                <i class="bi bi-archive"></i> Lost&Found
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link logout-btn" href="/user/logout">
                <i class="bi bi-box-arrow-right"></i> Logout
              </a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/user/signup">
                <i class="bi bi-pencil-square"></i> Signup
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/user/signin">
                <i class="bi bi-box-arrow-in-right"></i> Signin
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
