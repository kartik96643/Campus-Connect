<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      background: #f8f9fa;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .page-header {
      background: linear-gradient(135deg, #007bff, #6610f2);
      color: white;
      padding: 40px 20px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 40px;
    }
    .stat-card {
      border-radius: 15px;
      box-shadow: 0 6px 12px rgba(0,0,0,0.08);
      transition: transform 0.2s ease-in-out;
    }
    .stat-card:hover {
      transform: translateY(-5px);
    }
    .stat-icon {
      font-size: 2.5rem;
      color: #0d6efd;
    }
    .table {
      background: white;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .table thead {
      background: #0d6efd;
      color: white;
    }
    .table tbody tr:hover {
      background-color: #f1f1f1;
    }
  </style>
</head>
<body>
  <%- include('navbar.ejs') %>
  <% if(locals.user){ %>

  <div class="container mt-4">
    <!-- Page Header -->
    <div class="page-header text-center">
      <h1 class="fw-bold">Student Dashboard</h1>
      <p class="mb-0">Overview of student statistics across the platform</p>
    </div>

    <!-- Statistics Section -->
    <div class="row mb-4">
      <div class="col-md-4 mb-3">
        <div class="card stat-card text-center p-3">
          <div class="stat-icon mb-2"><i class="bi bi-people-fill"></i></div>
          <h5 class="fw-bold">Total Students</h5>
          <h2 class="text-primary fw-bold"><%= totalStudents %></h2>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card stat-card text-center p-3">
          <div class="stat-icon mb-2"><i class="bi bi-building"></i></div>
          <h5 class="fw-bold">Universities</h5>
          <h2 class="text-success fw-bold"><%= Object.keys(univCounts).length %></h2>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card stat-card text-center p-3">
          <div class="stat-icon mb-2"><i class="bi bi-journal-bookmark-fill"></i></div>
          <h5 class="fw-bold">Courses</h5>
          <h2 class="text-warning fw-bold"><%= Object.keys(courseCounts).length %></h2>
        </div>
      </div>
    </div>

    <!-- Data Tables -->
    <div class="row">
      <div class="col-md-6 mb-4">
        <div class="card p-3">
          <h4 class="mb-3"><i class="bi bi-building me-2"></i>Students per University</h4>
          <table class="table table-hover">
            <thead>
              <tr>
                <th>University</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <% for (let univ in univCounts) { %>
                <tr>
                  <td><%= univ %></td>
                  <td><%= univCounts[univ] %></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card p-3">
          <h4 class="mb-3"><i class="bi bi-journal me-2"></i>Students per Course</h4>
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Course</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <% for (let course in courseCounts) { %>
                <tr>
                  <td><%= course %></td>
                  <td><%= courseCounts[course] %></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="col-md-12 mb-4">
        <div class="card p-3">
          <h4 class="mb-3"><i class="bi bi-gender-ambiguous me-2"></i>Students per Gender</h4>
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Gender</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <% for (let sex in sexCounts) { %>
                <tr>
                  <td><%= sex %></td>
                  <td><%= sexCounts[sex] %></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <% }else{ %>
    <h4 class="mt-4 text-center">You have to create account or login your account to access this.</h4>
          <% } %>
</body>
</html>
