<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Private Chat</title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="/socket.io/socket.io.js"></script>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #e5ddd5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .chat-container {
            width: 400px;
            height: 500px;
            background: #f0f0f0;
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .chat-header {
            background: #075e54;
            color: white;
            padding: 15px;
            font-size: 18px;
            text-align: center;
        }

        #chat-box {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .message {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 15px;
            word-wrap: break-word;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .sent {
            background: #dcf8c6;
            align-self: flex-end;
        }

        .received {
            background: white;
            align-self: flex-start;
        }

        .sender-name {
            font-size: 12px;
            font-weight: bold;
            margin-bottom: 5px;
            color: #075e54;
        }

        .timestamp {
            font-size: 11px;
            color: gray;
            align-self: flex-end;
            margin-top: 3px;
        }

        .chat-input {
            display: flex;
            border-top: 1px solid #ccc;
            background: #eee;
            padding: 10px;
        }

        .chat-input input {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 20px;
            outline: none;
        }

        .chat-input button {
            margin-left: 10px;
            padding: 10px 15px;
            border: none;
            border-radius: 20px;
            background: #075e54;
            color: white;
            cursor: pointer;
            font-weight: bold;
        }

        .chat-input button:hover {
            background: #128c7e;
        }

        /* Scrollbar style */
        #chat-box::-webkit-scrollbar {
            width: 6px;
        }

        #chat-box::-webkit-scrollbar-thumb {
            background-color: rgba(0, 0, 0, 0.2);
            border-radius: 3px;
        }

        .btn{
            background-color: #075e54;
            border-top-left-radius: 0px;
            border-top-right-radius: 0px;

        }
        .btn:hover{
            background-color:#128c7e ;
        }
    </style>
</head>

<body>
    <% if(locals.user){ %>
        <div class="chat-container">
            <div class="chat-header">Chat with <%= student.name %></div>

            <!-- Hidden inputs for IDs -->
            <% let username=student.name%>
            <input type="hidden" id="username" value="<%= username %>">
            <input type="hidden" id="senderId" value="<%= user._id %>">
            <input type="hidden" id="receiverId" value="<%= student._id %>">

            <div id="chat-box">
                <% if(chats && chats.length > 0) { %>
                    <% chats.forEach(c=> { %>
                        <div class="message <%= c.senderId.toString() === user._id.toString() ? 'sent' : 'received' %>">
                            <div class="sender-name">
                                <%= c.senderId.toString() !== user._id.toString() ? student.name : "You" %>
                            </div>
                            <div><%= c.message %></div>
                            <div class="timestamp">
                                <%= c.timestamp.toLocaleTimeString('en-Us',{hour: '2-digit' , minute: '2-digit', hour12: true}) %>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="chat-input">
                <input type="text" id="message" placeholder="Type a message">
                <button id="send">Send</button>
            </div>
            <button class="btn mt-2"><a class="btn text-light" href="/">Back to Home</a></button>
        </div>

        <script>
            const socket = io();

            const senderId = document.getElementById("senderId").value;
            const receiverId = document.getElementById("receiverId").value;
            const username = document.getElementById("username").value;

            socket.emit("registered", senderId);

            // Scroll to bottom when page loads
            window.addEventListener("DOMContentLoaded", () => {
                const chatBox = document.getElementById("chat-box");
                chatBox.scrollTop = chatBox.scrollHeight;
            });

            // Send message
            document.getElementById("send").addEventListener("click", function () {
                let message = document.getElementById("message").value;
                if (!message.trim()) return;

                socket.emit("privateMessage", { senderId, receiverId, message });

                const chatBox = document.getElementById("chat-box");
                const now = new Date();
                const time = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

                chatBox.innerHTML += `
                  <div class="message sent">
                    <div class="sender-name">You</div>
                    <div>${message}</div>
                    <div class="timestamp">${time}</div>
                  </div>`;
                
                chatBox.scrollTop = chatBox.scrollHeight;
                document.getElementById("message").value = "";
            });

            // Receive message
            socket.on("privateMessage", (data) => {
                const chatBox = document.getElementById("chat-box");
                const now = new Date();
                const time = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

                chatBox.innerHTML += `
                  <div class="message received">
                    <div class="sender-name">${username}</div>
                    <div>${data.message}</div>
                    <div class="timestamp">${time}</div>
                  </div>`;
                
                chatBox.scrollTop = chatBox.scrollHeight;
            });
        </script>
    <% } else{%>
        <h4 class="mt-4 text-center">You have to create account or login your account to access this.</h4>
          <% } %>
</body>
</html>
