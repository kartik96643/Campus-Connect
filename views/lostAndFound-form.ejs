<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lost & Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f4f6f9;
            min-height: 100vh;
            margin: 0;
        }

        .container-body {
            margin: auto;
            width: 450px;
            background: #fff;
            margin-top: 60px;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 6px 25px rgba(0, 0, 0, 0.1);
        }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 25px;
            font-weight: bold;
        }

        label {
            font-weight: bold;
            color: #444;
            margin-top: 10px;
        }

        input[type="file"],
        textarea {
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            outline: none;
            width: 100%;
            transition: border 0.2s;
        }

        input[type="file"]:focus,
        textarea:focus {
            border-color: #007bff;
        }

        button[type="submit"] {
            background: #007bff;
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            border: none;
            padding: 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 20px;
            width: 100%;
        }

        button[type="submit"]:hover {
            background: #0056b3;
        }

        .btn-list {
            margin-top: 10px;
            width: 100%;
        }

        /* Alert Styles */
        .forSec {
            padding: 12px 15px;
            margin-bottom: 15px;
            border-radius: 6px;
            text-align: center;
            font-weight: bold;
            animation: fadeOut 4s forwards;
        }

        .success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        @keyframes fadeOut {
            0% { opacity: 1; }
            80% { opacity: 1; }
            100% { opacity: 0; display: none; }
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>
    <% if(locals.user) { %>

        <div class="container-body">
            <% if(typeof msg !== 'undefined' && msg){ %>
                <div class="forSec <%= type %>"><%= msg %></div>
            <% } %>

            <h2>Lost & Found</h2>

            <form action="/lostandfound" method="post" enctype="multipart/form-data">
                <input type="hidden" name="founderId" value="<%= locals.user._id %>">

                <label for="item-image">Item Image</label>
                <input type="file" name="item-image" id="item-image" required> 

                <label for="message">Description</label>
                <textarea name="message" id="message" placeholder="Describe the item..." required rows="4"></textarea>

                <button type="submit">Submit</button>
            </form>

            <a href="/lostandfound/all" class="btn btn-outline-primary btn-list">View Lost & Found List</a>
        </div>
   
        <% } else{%>
    <h4 class="mt-4 text-center">You have to create account or login your account to access this.</h4>
          <% } %>

</body>
</html>
