<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet"
    crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    body {
      min-height: 100vh;
      margin: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Nunito', sans-serif;
      background: linear-gradient(135deg, #f9f9f9, #eaeaea);
      position: relative;
    }

    .signin-card {
      font-family: 'Nunito', sans-serif;
      position: relative;
      z-index: 1;
      background: rgba(255, 255, 255, 0.85);
      border-radius: 20px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
      backdrop-filter: blur(15px);
      padding: 2.5rem;
      max-width: 420px;
      width: 100%;
      color: #333;
    }

    .signin-card h3 {
      font-weight: 700;
      color: #222;
    }

    .form-label {
      font-weight: 600;
      color: #444;
    }

    .form-control {
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(0, 0, 0, 0.1);
      color: #333;
    }

    .form-control::placeholder {
      color: #888;
    }

    .form-control:focus {
      background-color: #fff;
      border-color: #0d6efd;
      box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
      color: #333;
    }

    .btn-primary {
      background: #0d6efd;
      border: none;
      font-weight: bold;
      transition: all 0.3s ease-in-out;
    }

    .btn-primary:hover {
      background: #0b5ed7;
      transform: scale(1.02);
    }

    .form-text {
      font-size: 0.85rem;
      color: #555;
    }

    .alert {
      max-width: 420px;
      margin-bottom: 1rem;
      background-color: rgba(220, 53, 69, 0.2);
      border: none;
      backdrop-filter: blur(5px);
      color: #b02a37;
      z-index: 1;
    }

    a.text-primary {
      color: #0d6efd !important;
    }

    a.text-primary:hover {
      color: #0b5ed7 !important;
    }

    .position-relative .toggle-password {
      position: absolute;
      top: 75%;
      right: 15px;
      transform: translateY(-50%);
      cursor: pointer;
      font-size: 1.2rem;
      color: #666;
    }

    .link-group a {
      margin: 0 39px;
      display: inline-block;
    }

    .account-text {
  font-size: 0.95rem;
  color: #555;
  margin-top: 0.5rem;
}

.account-text .signup-link {
  font-weight: 600;
  color: #0d6efd;
  text-decoration: none;
  transition: color 0.2s ease-in-out;
}

.account-text .signup-link:hover {
  color: #0b5ed7;
  text-decoration: underline;
}

  </style>
</head>

<body>
  <div class="signin-card">
    <% if(errors && errors.length> 0){ %> 
      <div class="alert alert-danger forSec">
        <ul class="mb-0">
          <% errors.forEach(e=> { %> 
            <li><%= e.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <h3 class="text-center mb-4">Sign in to your account</h3>
    <form method="post" action="/user/signin">
      <div class="mb-3"> 
        <label for="email" class="form-label">Email address</label> 
        <input type="email" class="form-control" id="email" name="email"
          value="<%= formdata && formdata.email ? formdata.email : '' %>">
        <div id="emailHelp" class="form-text">We'll never share your email with anyone else.</div>
        <% if(errors && errors.length){ for(let i=0; i < errors.length; i++){ if(errors[i].param==='email' ){ %>
          <p class="text-danger mt-1"><%= errors[i].msg %></p>
        <% break; }}} %>
      </div>

      <div class="mb-3 position-relative"> 
        <label for="password" class="form-label">Password</label> 
        <input type="password" class="form-control" id="password" name="password"> 
        <span class="toggle-password" onclick="togglePassword()">👁️</span> 
      </div>

      <div class="d-grid text-center">
  <button type="submit" class="btn btn-primary mb-3">Sign In</button>
  <p class="account-text">
    Don’t have an account? 
    <a href="/user/signup" class="signup-link">Create</a>
  </p>
</div>

    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"
    crossorigin="anonymous"></script>

  <script>
    function togglePassword() {
      const pwd = document.getElementById("password");
      const type = pwd.getAttribute("type") === "password" ? "text" : "password";
      pwd.setAttribute("type", type);
    }
    window.addEventListener("DOMContentLoaded", () => {
      const alert = document.querySelector(".forSec");
      if (alert) {
        setTimeout(() => {
          alert.style.opacity = "0";
          setTimeout(() => {
            alert.style.display = "none";
          }, 500);
        }, 2000);
      }
    });
  </script>
</body>

</html>
